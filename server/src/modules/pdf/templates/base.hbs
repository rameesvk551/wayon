<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{{trip.title}} - Travel Itinerary</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:wght@400;500;600;700;800;900&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      /* ═══════════════════════════════════════════════════════════
         PREMIUM TRAVEL INFOGRAPHIC DESIGN SYSTEM
         Map-Based Storytelling • Leader Lines • Icon-Driven
         70-20-10 Color Rule • Premium Typography
         ═══════════════════════════════════════════════════════════ */

      :root {
        /* ─── 70% Neutral Background ─── */
        --bg-primary: #f7f9fc;
        --bg-white: #ffffff;
        --bg-surface: #f1f5f9;
        --bg-muted: #e8edf4;

        /* ─── 20% Brand Colors ─── */
        --brand-900: #0c1929;
        --brand-800: #122643;
        --brand-700: #1a365d;
        --brand-600: #1e4d8c;
        --brand-500: #2563eb;
        --brand-400: #3b82f6;
        --brand-300: #60a5fa;
        --brand-200: #93c5fd;
        --brand-100: #dbeafe;
        --brand-50: #eff6ff;

        /* ─── 10% Accent Colors ─── */
        --accent-teal: #0d9488;
        --accent-amber: #d97706;
        --accent-rose: #e11d48;
        --accent-emerald: #059669;
        --accent-sky: #0ea5e9;
        --accent-violet: #7c3aed;
        --accent-orange: #ea580c;

        /* ─── Text Colors ─── */
        --text-primary: #0f172a;
        --text-secondary: #334155;
        --text-tertiary: #64748b;
        --text-muted: #94a3b8;
        --text-faint: #cbd5e1;

        /* ─── Borders ─── */
        --border-light: #e2e8f0;
        --border-medium: #cbd5e1;
        --border-subtle: #f1f5f9;

        /* ─── Fonts ─── */
        --font-display: 'Playfair Display', Georgia, 'Times New Roman', serif;
        --font-body: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --font-label: 'DM Sans', 'Inter', sans-serif;

        /* ─── Spacing ─── */
        --page-pad: 36px;
        --section-gap: 28px;

        /* ─── Radii ─── */
        --r-xs: 6px;
        --r-sm: 10px;
        --r-md: 16px;
        --r-lg: 24px;
        --r-xl: 32px;
        --r-full: 999px;

        /* ─── Shadows ─── */
        --shadow-xs: 0 1px 2px rgba(15,23,42,0.04);
        --shadow-sm: 0 1px 3px rgba(15,23,42,0.05), 0 2px 8px rgba(15,23,42,0.04);
        --shadow-md: 0 4px 6px rgba(15,23,42,0.04), 0 8px 20px rgba(15,23,42,0.06);
        --shadow-lg: 0 8px 12px rgba(15,23,42,0.04), 0 16px 40px rgba(15,23,42,0.08);
        --shadow-xl: 0 12px 20px rgba(15,23,42,0.06), 0 24px 56px rgba(15,23,42,0.10);
        --shadow-glow: 0 0 20px rgba(37,99,235,0.15), 0 0 60px rgba(37,99,235,0.08);
      }

      @page {
        size: {{output.format}};
        margin: 0;
      }

      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        margin: 0;
        font-family: var(--font-body);
        color: var(--text-primary);
        background: var(--bg-white);
        font-size: 13px;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }

      /* ═══════════════════════════════════════════
         PAGE SYSTEM
         ═══════════════════════════════════════════ */
      .page {
        width: 100%;
        min-height: 100vh;
        page-break-after: always;
        position: relative;
        overflow: hidden;
        background: var(--bg-white);
      }
      .page:last-child { page-break-after: auto; }

      .page--padded {
        padding: var(--page-pad);
      }

      .page--cover {
        padding: 0;
        background: linear-gradient(165deg, #0a1628 0%, #0f2340 35%, #162f5a 65%, #1a365d 100%);
        color: #ffffff;
        display: flex;
        flex-direction: column;
      }

      .page--light {
        background: var(--bg-primary);
      }

      /* ═══════════════════════════════════════════
         TYPOGRAPHY
         ═══════════════════════════════════════════ */
      .font-display { font-family: var(--font-display); }
      .font-label { font-family: var(--font-label); }

      .heading-hero {
        font-family: var(--font-display);
        font-size: 56px;
        font-weight: 800;
        line-height: 1.05;
        letter-spacing: -0.02em;
      }

      .heading-xl {
        font-family: var(--font-display);
        font-size: 32px;
        font-weight: 800;
        line-height: 1.15;
        letter-spacing: -0.01em;
        color: var(--text-primary);
      }

      .heading-lg {
        font-size: 22px;
        font-weight: 800;
        line-height: 1.2;
        color: var(--text-primary);
      }

      .heading-md {
        font-size: 16px;
        font-weight: 700;
        line-height: 1.3;
        color: var(--text-primary);
      }

      .heading-sm {
        font-size: 13px;
        font-weight: 700;
        line-height: 1.4;
        color: var(--text-primary);
      }

      .label-upper {
        font-family: var(--font-label);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .label-sm {
        font-family: var(--font-label);
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.02em;
      }

      .text-body { font-size: 13px; color: var(--text-secondary); line-height: 1.55; }
      .text-sm { font-size: 11px; color: var(--text-tertiary); line-height: 1.5; }
      .text-xs { font-size: 10px; color: var(--text-muted); line-height: 1.4; }

      .text-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      /* ═══════════════════════════════════════════
         COMPONENTS
         ═══════════════════════════════════════════ */

      /* ─── Tags & Badges ─── */
      .tag {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 12px;
        border-radius: var(--r-full);
        font-size: 10px;
        font-weight: 600;
        background: var(--bg-surface);
        color: var(--text-tertiary);
        letter-spacing: 0.02em;
      }

      .tag--brand {
        background: var(--brand-50);
        color: var(--brand-600);
        border: 1px solid var(--brand-100);
      }

      .tag--accent {
        background: linear-gradient(135deg, #e0f2fe, #e0e7ff);
        color: var(--brand-600);
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: var(--r-sm);
        font-size: 12px;
        font-weight: 700;
        background: linear-gradient(135deg, var(--brand-50), #ede9fe);
        color: var(--brand-600);
        border: 1px solid var(--brand-100);
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 20px;
        border-radius: var(--r-md);
        font-size: 14px;
        font-weight: 700;
        line-height: 1;
      }

      .pill--glass {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.12);
        color: #ffffff;
        backdrop-filter: blur(8px);
      }

      .pill--solid {
        background: var(--brand-50);
        border: 1px solid var(--brand-100);
        color: var(--brand-600);
      }

      /* ─── Dividers ─── */
      .divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--border-light), transparent);
        margin: 20px 0;
      }

      .divider--strong {
        height: 2px;
        background: linear-gradient(90deg, var(--brand-400), var(--accent-sky), var(--accent-teal));
      }

      /* ─── Cards ─── */
      .card {
        background: var(--bg-white);
        border: 1px solid var(--border-light);
        border-radius: var(--r-md);
        overflow: hidden;
      }

      .card--elevated {
        box-shadow: var(--shadow-md);
      }

      .card--glass {
        background: rgba(255,255,255,0.06);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.10);
      }

      .card--glass-strong {
        background: rgba(255,255,255,0.10);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,0.15);
        box-shadow: 0 4px 24px rgba(0,0,0,0.15);
      }

      /* ─── Map Container ─── */
      .map-frame {
        border-radius: var(--r-lg);
        overflow: hidden;
        border: 2px solid rgba(255,255,255,0.12);
        box-shadow: var(--shadow-xl), var(--shadow-glow);
        position: relative;
      }

      .map-frame__image {
        width: 100%;
        display: block;
        background-size: cover;
        background-position: center;
        background-color: #1a365d;
      }

      .map-frame__overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 10px 16px;
        background: linear-gradient(to top, rgba(0,0,0,0.5), transparent);
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .map-frame__badge {
        padding: 4px 12px;
        border-radius: var(--r-xs);
        font-size: 10px;
        font-weight: 600;
        background: rgba(0,0,0,0.45);
        backdrop-filter: blur(4px);
        color: rgba(255,255,255,0.85);
      }

      /* ─── Activity Icon ─── */
      .activity-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: var(--r-xs);
        background: var(--brand-50);
        color: var(--brand-500);
        flex-shrink: 0;
      }

      .activity-icon svg {
        width: 16px;
        height: 16px;
      }

      .activity-icon--sm {
        width: 22px;
        height: 22px;
      }

      .activity-icon--sm svg {
        width: 13px;
        height: 13px;
      }

      .activity-icon--lg {
        width: 36px;
        height: 36px;
        border-radius: var(--r-sm);
      }
      .activity-icon--lg svg {
        width: 20px;
        height: 20px;
      }

      .activity-icon--teal { background: #f0fdfa; color: var(--accent-teal); }
      .activity-icon--amber { background: #fffbeb; color: var(--accent-amber); }
      .activity-icon--rose { background: #fff1f2; color: var(--accent-rose); }
      .activity-icon--emerald { background: #ecfdf5; color: var(--accent-emerald); }
      .activity-icon--violet { background: #f5f3ff; color: var(--accent-violet); }
      .activity-icon--sky { background: #f0f9ff; color: var(--accent-sky); }
      .activity-icon--orange { background: #fff7ed; color: var(--accent-orange); }

      .activity-icon--glass {
        background: rgba(255,255,255,0.10);
        color: rgba(255,255,255,0.8);
      }

      /* ─── Activity Card ─── */
      .act-card {
        background: var(--bg-white);
        border: 1px solid var(--border-light);
        border-radius: var(--r-md);
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }

      .act-card__image {
        width: 100%;
        height: 100px;
        object-fit: cover;
        display: block;
      }

      .act-card__placeholder {
        width: 100%;
        height: 100px;
        background: linear-gradient(135deg, var(--bg-surface), var(--bg-muted));
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
        font-size: 28px;
      }

      .act-card__body {
        padding: 12px 14px 14px;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .act-card__name {
        font-size: 13px;
        font-weight: 700;
        color: var(--text-primary);
        line-height: 1.3;
      }

      .act-card__desc {
        font-size: 11px;
        color: var(--text-tertiary);
        line-height: 1.45;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .act-card__meta {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-top: auto;
        padding-top: 6px;
      }

      /* ─── Destination Card (Cover) ─── */
      .dest-card {
        padding: 14px 16px;
        border-radius: var(--r-md);
        background: rgba(255,255,255,0.06);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.10);
        transition: all 0.3s ease;
      }

      .dest-card:hover {
        background: rgba(255,255,255,0.10);
        border-color: rgba(255,255,255,0.18);
        transform: translateY(-2px);
      }

      .dest-card__label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.08em;
        margin-bottom: 4px;
      }

      .dest-card__title {
        font-size: 16px;
        font-weight: 800;
        color: #ffffff;
        line-height: 1.2;
        margin-bottom: 2px;
      }

      .dest-card__subtitle {
        font-size: 11px;
        color: rgba(255,255,255,0.5);
        margin-bottom: 8px;
      }

      .dest-card__icons {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
      }

      .dest-card__category {
        display: inline-block;
        padding: 2px 10px;
        border-radius: var(--r-full);
        font-size: 9px;
        font-weight: 600;
        background: rgba(255,255,255,0.10);
        color: rgba(255,255,255,0.7);
        letter-spacing: 0.04em;
        margin-top: 6px;
      }

      /* ─── Transport Card ─── */
      .transport-card {
        background: linear-gradient(135deg, var(--bg-surface), var(--bg-muted));
        border: 1px solid var(--border-light);
        border-radius: var(--r-md);
        padding: 14px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
      }

      /* ─── Hotel Card ─── */
      .hotel-card {
        background: linear-gradient(135deg, #fefce8, #fef3c7);
        border: 1px solid #fde68a;
        border-radius: var(--r-md);
        padding: 14px 16px;
      }

      /* ─── Page Header ─── */
      .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 14px;
        margin-bottom: 20px;
        border-bottom: 2px solid var(--border-light);
      }

      .page-header__brand {
        font-family: var(--font-label);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--text-muted);
      }

      .page-header__page {
        font-size: 10px;
        font-weight: 600;
        color: var(--text-muted);
      }

      /* ─── Section Title ─── */
      .section-label {
        font-family: var(--font-label);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 6px;
      }

      .section-heading {
        font-family: var(--font-display);
        font-size: 26px;
        font-weight: 800;
        color: var(--text-primary);
        line-height: 1.2;
      }

      /* ─── Data Table ─── */
      .data-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
      }

      .data-table thead {
        background: var(--bg-surface);
      }

      .data-table th {
        padding: 10px 14px;
        text-align: left;
        font-weight: 700;
        font-size: 10px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--text-tertiary);
        border-bottom: 2px solid var(--border-light);
      }

      .data-table td {
        padding: 10px 14px;
        border-bottom: 1px solid var(--border-subtle);
        color: var(--text-secondary);
      }

      .data-table tbody tr:last-child td {
        border-bottom: none;
      }

      /* ─── Leader Lines (SVG) ─── */
      .leader-lines-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 2;
      }

      .leader-line {
        fill: none;
        stroke-width: 2;
        stroke-dasharray: 6 4;
        opacity: 0.5;
      }

      .leader-dot {
        r: 4;
        opacity: 0.7;
      }

      /* ─── Journey Flow ─── */
      .journey-line {
        position: absolute;
        left: 50%;
        top: 0;
        bottom: 0;
        width: 3px;
        background: linear-gradient(to bottom, var(--brand-200), var(--brand-400), var(--brand-200));
        border-radius: 2px;
        z-index: 0;
      }

      .journey-dot {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: var(--brand-500);
        border: 3px solid var(--bg-white);
        box-shadow: var(--shadow-sm);
        position: relative;
        z-index: 1;
      }

      /* ─── Day Banner ─── */
      .day-banner {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px 20px;
        border-radius: var(--r-md);
        margin-bottom: 20px;
      }

      .day-banner__number {
        font-family: var(--font-display);
        font-size: 42px;
        font-weight: 900;
        line-height: 1;
        opacity: 0.9;
      }

      .day-banner__info {
        flex: 1;
      }

      .day-banner__city {
        font-family: var(--font-display);
        font-size: 22px;
        font-weight: 800;
        line-height: 1.15;
      }

      .day-banner__date {
        font-size: 12px;
        font-weight: 500;
        opacity: 0.7;
        margin-top: 2px;
      }

      .day-banner__stats {
        display: flex;
        gap: 8px;
      }

      /* ─── Utilities ─── */
      .flex { display: flex; }
      .flex-col { flex-direction: column; }
      .flex-wrap { flex-wrap: wrap; }
      .items-center { align-items: center; }
      .justify-between { justify-content: space-between; }
      .gap-4 { gap: 4px; }
      .gap-6 { gap: 6px; }
      .gap-8 { gap: 8px; }
      .gap-10 { gap: 10px; }
      .gap-12 { gap: 12px; }
      .gap-16 { gap: 16px; }
      .gap-20 { gap: 20px; }
      .gap-24 { gap: 24px; }
      .mt-auto { margin-top: auto; }
      .mb-4 { margin-bottom: 4px; }
      .mb-8 { margin-bottom: 8px; }
      .mb-12 { margin-bottom: 12px; }
      .mb-16 { margin-bottom: 16px; }
      .mb-20 { margin-bottom: 20px; }
      .mb-24 { margin-bottom: 24px; }
      .p-12 { padding: 12px; }
      .p-16 { padding: 16px; }
      .p-20 { padding: 20px; }
      .px-16 { padding-left: 16px; padding-right: 16px; }
      .py-8 { padding-top: 8px; padding-bottom: 8px; }
      .w-full { width: 100%; }
      .text-center { text-align: center; }
      .text-white { color: #ffffff; }
      .opacity-50 { opacity: 0.5; }
      .opacity-70 { opacity: 0.7; }
      .relative { position: relative; }
      .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
      .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; }
      .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }

      /* ─── SVG Activity Icons (Inline Definitions) ─── */
      .icon-svg { width: 16px; height: 16px; fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
      .icon-svg--sm { width: 13px; height: 13px; }
      .icon-svg--lg { width: 20px; height: 20px; }

      /* ─── Star Rating ─── */
      .stars { display: flex; gap: 2px; color: #f59e0b; }
      .star { font-size: 12px; }
    </style>
  </head>
  <body>
    {{#if output.includeInfographicCover}}
      {{> infographic}}
    {{/if}}
    {{> mapOverview}}
    {{#each days}}
      {{> dayPage dayIndex=@index totalDays=../days.length trip=../trip branding=../branding mapEnhancementsEnabled=../mapEnhancementsEnabled}}
    {{/each}}
  </body>
</html>
