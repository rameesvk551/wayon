{{!-- ═══════════════════════════════════════════════════════════════════
     MAP OVERVIEW PAGE
     Full trip route visualization with day legend & summary tables
     ═══════════════════════════════════════════════════════════════════ --}}

{{#if mapEnhancementsEnabled}}
<section class="page page--padded page--light">
  {{!-- Page Header --}}
  <div class="page-header">
    <div class="page-header__brand">{{trip.destination}} &bull; Trip Overview</div>
    <div class="page-header__page">Overview</div>
  </div>

  {{!-- Section Title --}}
  <div class="mb-20">
    <div class="section-label">
      <svg class="icon-svg icon-svg--sm" style="vertical-align: middle; margin-right: 4px;" viewBox="0 0 24 24"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
      Trip Geo Overview
    </div>
    <div class="section-heading font-display">Complete Route Map</div>
    <div class="text-sm" style="margin-top: 4px;">All attractions with day-by-day route flow &bull; {{trip.totalDays}} days, {{trip.destination}}</div>
  </div>

  {{!-- Overview Map --}}
  <div class="card card--elevated mb-20" style="border-radius: var(--r-lg); overflow: hidden;">
    <div style="position: relative;">
      <div style="width: 100%; height: 360px; background-image: url('{{{overviewMapImage}}}'); background-size: cover; background-position: center; background-color: var(--bg-muted);"></div>
      {{!-- Map overlay with gradient --}}
      <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 12px 20px; background: linear-gradient(to top, rgba(15,23,42,0.6), transparent);">
        <div class="flex justify-between items-center">
          <div class="flex gap-8">
            {{#each dayLegend}}
              <div class="flex items-center gap-4">
                <span style="width: 10px; height: 10px; border-radius: 50%; background: {{colorHex}}; display: inline-block; box-shadow: 0 0 6px {{colorHex}}88;"></span>
                <span class="label-sm" style="color: rgba(255,255,255,0.85);">Day {{dayNumber}}</span>
              </div>
            {{/each}}
          </div>
          <span class="label-sm" style="color: rgba(255,255,255,0.5);">Interactive Route</span>
        </div>
      </div>
    </div>
  </div>

  {{!-- Day Legend Chips --}}
  {{#if dayLegend.length}}
    <div class="mb-16 flex flex-wrap gap-8">
      {{#each dayLegend}}
        <div class="tag" style="background: {{colorHex}}10; border: 1px solid {{colorHex}}25;">
          <span style="width: 10px; height: 10px; border-radius: 50%; background: {{colorHex}}; display: inline-block;"></span>
          <span class="label-sm" style="color: var(--text-secondary);">Day {{dayNumber}}</span>
          <span style="color: var(--text-muted);">&middot; {{colorName}}</span>
        </div>
      {{/each}}
    </div>
  {{/if}}

  {{!-- Summary Tables Side by Side --}}
  <div style="display: grid; grid-template-columns: {{#if clusterSummaryRows.length}}1fr 1fr{{else}}1fr{{/if}}; gap: 16px;">
    {{!-- Distance Summary --}}
    {{#if distanceSummaryRows.length}}
      <div class="card card--elevated">
        <div style="padding: 14px 18px; border-bottom: 1px solid var(--border-light);">
          <div class="heading-sm flex items-center gap-8">
            <div class="activity-icon activity-icon--sm activity-icon--sky">
              <svg class="icon-svg icon-svg--sm" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            Distance &amp; Time Summary
          </div>
        </div>
        <table class="data-table">
          <thead>
            <tr>
              <th>Day</th>
              <th>Stops</th>
              <th>Distance</th>
              <th>Est. Time</th>
            </tr>
          </thead>
          <tbody>
            {{#each distanceSummaryRows}}
              <tr>
                <td>
                  <span class="flex items-center gap-6">
                    <span style="width: 8px; height: 8px; border-radius: 50%; background: {{dayColorHex}};"></span>
                    <span style="font-weight: 700;">Day {{dayNumber}}</span>
                  </span>
                </td>
                <td>
                  <span class="tag tag--brand" style="font-size: 10px; padding: 2px 8px;">{{stopCount}}</span>
                </td>
                <td style="font-weight: 700; color: var(--brand-600);">{{totalDistanceLabel}}</td>
                <td class="text-sm">{{totalTimeLabel}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{/if}}

    {{!-- Cluster Summary --}}
    {{#if clusterSummaryRows.length}}
      <div class="card card--elevated">
        <div style="padding: 14px 18px; border-bottom: 1px solid var(--border-light);">
          <div class="heading-sm flex items-center gap-8">
            <div class="activity-icon activity-icon--sm activity-icon--teal">
              <svg class="icon-svg icon-svg--sm" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            Area Clusters
          </div>
        </div>
        <table class="data-table">
          <thead>
            <tr>
              <th>Cluster</th>
              <th>Markers</th>
              <th>Stops</th>
              <th>Center</th>
            </tr>
          </thead>
          <tbody>
            {{#each clusterSummaryRows}}
              <tr>
                <td>
                  <span class="flex items-center gap-6">
                    <span style="width: 8px; height: 8px; border-radius: 50%; background: {{colorHex}};"></span>
                    <span style="font-weight: 700;">{{name}}</span>
                  </span>
                </td>
                <td>{{markerCount}}</td>
                <td>{{stopCount}}</td>
                <td class="text-xs">{{#if centerLabel}}{{centerLabel}}{{else}}&mdash;{{/if}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{/if}}
  </div>
</section>
{{/if}}
